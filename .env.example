# Copy to .env and fill in real values. .env is git-ignored.

test.mail.email=you@example.com
test.mail.password=app-password-or-account-password
test.mail.imap.host=imap.example.com
test.mail.imap.port=993
test.mail.smtp.host=smtp.example.com
test.mail.smtp.port=465
test.mail.smtp.starttls=false

# Optional; defaults to test.mail.email when unset.
test.mail.recipient=
