    <string name="onboarding_p1_eyebrow">01 · REMOTE-FIRST</string>
    <string name="onboarding_p1_title">The phone is the cockpit.</string>
    <string name="onboarding_p1_body">Email a command to your claude-email service. It spawns an agent in the target project and replies when the work is done — no ssh, no VPN, no terminal open.</string>

    <string name="onboarding_p2_eyebrow">02 · MULTI-SURFACE</string>
    <string name="onboarding_p2_title">Threads that survive reboots.</string>
    <string name="onboarding_p2_body">Each task is a conversation, stored on the backend and visible from the app, the dashboard, and the original email thread — pick it up wherever you are.</string>

    <string name="onboarding_p3_eyebrow">03 · ON-DEVICE</string>
    <string name="onboarding_p3_title">Credentials stay on device.</string>
    <string name="onboarding_p3_body">IMAP and SMTP passwords sit in the Android Keystore. Nothing leaves the phone except mail you explicitly send.</string>
