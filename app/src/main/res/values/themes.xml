<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ClaudeEmailApp" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/pitch_black</item>
        <item name="android:statusBarColor">@color/pitch_black</item>
        <item name="android:navigationBarColor">@color/pitch_black</item>
    </style>

    <style name="Theme.ClaudeEmailApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pitch_black</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.ClaudeEmailApp</item>
    </style>

</resources>
